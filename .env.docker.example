# ============================================================================
# AdaptiMultiRAG Docker 部署环境变量模板
# ============================================================================
# 使用说明:
#   1. 复制此文件为 .env
#      cp .env.docker.example .env
#   2. 编辑 .env 填写实际配置值
#   3. 启动所有服务: docker compose up -d
#
# 重要: 所有 host 地址使用 Docker Compose 服务名（非 localhost）
# ============================================================================

# ============================================================================
# Docker 基础设施配置
# ============================================================================

# MySQL root 密码（必需）
MYSQL_ROOT_PASSWORD=change_me_mysql_root_password

# MySQL 数据库名
MYSQL_DATABASE=rag_db

# PostgreSQL 管理员密码（必需）
POSTGRES_PASSWORD=change_me_postgres_password

# PostgreSQL 数据库名（LangGraph checkpoint 和 langmem 记忆存储）
POSTGRES_DATABASE=rag_checkpoint

# PostgreSQL 用户名
POSTGRES_USER=postgres

# MinIO 凭证（Milvus 对象存储）
MINIO_ACCESS_KEY=change_me_minio_access_key
MINIO_SECRET_KEY=change_me_minio_secret_key

# Neo4j 认证（必需 - 格式: username/password）
# LightRAG 知识图谱存储使用
NEO4J_AUTH=neo4j/change_me_neo4j_password

# Redis 密码（必需）
REDIS_PASSWORD=change_me_redis_password

# ============================================================================
# 数据库配置
# ============================================================================

# MySQL 业务数据库连接（host 为 Docker 服务名 mysql）
DB_URL=mysql+pymysql://root:changeme_mysql_root@mysql:3306/rag_db

# PostgreSQL / LangGraph Checkpoint（host 为 Docker 服务名 postgres）
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# POSTGRES_DATABASE 见上方 Docker 基础设施配置
# POSTGRES_USER 见上方 Docker 基础设施配置
# POSTGRES_PASSWORD 见上方 Docker 基础设施配置

# ============================================================================
# API 密钥配置
# ============================================================================

# 通用 API 密钥（可选；也可以分别填写下面的 LLM / VECTOR key）
DASHSCOPE_API_KEY=your_dashscope_api_key

# LLM 模型配置（智谱 BigModel，兼容 OpenAI 格式；留空时复用 VECTOR_DASHSCOPE_API_KEY）
LLM_DASHSCOPE_API_KEY=your_llm_dashscope_api_key
LLM_DASHSCOPE_API_BASE=https://open.bigmodel.cn/api/paas/v4
LLM_DASHSCOPE_CHAT_MODEL=glm-5.2

# 向量模型配置（智谱 BigModel，兼容 OpenAI 格式）
VECTOR_DASHSCOPE_API_KEY=your_vector_dashscope_api_key
VECTOR_DASHSCOPE_API_BASE=https://open.bigmodel.cn/api/paas/v4
VECTOR_DASHSCOPE_EMBEDDING_MODEL=embedding-3

# 向量维度（embedding-3 默认 2048）
EMBEDDING_DIM=2048

# MinerU OCR 服务（可选 - 用于文档 OCR 识别）
# MINERU_API_URL=http://your-mineru-service-url
# MINERU_API_KEY=your-mineru-api-key

# DeepSeek API 密钥（可选 - 如使用 DeepSeek 模型）
# DEEPSEEK_API_KEY=your-deepseek-api-key

# ============================================================================
# 向量数据库配置 - Milvus
# ============================================================================

MILVUS_URI=http://milvus:19530
MILVUS_DB_NAME=default
MILVUS_TOKEN=

# Collection 名称由系统自动生成，格式: kb{library_id}_{timestamp_ms}

# ============================================================================
# 图数据库配置 - LightRAG + Neo4j
# ============================================================================

# 图存储后端
LIGHTRAG_GRAPH_STORAGE=Neo4JStorage

# KV 存储后端
LIGHTRAG_KV_STORAGE=PGKVStorage

# 文档状态存储后端
LIGHTRAG_DOC_STATUS_STORAGE=PGDocStatusStorage

# 向量存储后端
LIGHTRAG_VECTOR_STORAGE=MilvusVectorDBStorage

# Neo4j 连接参数（LightRAG Neo4JStorage 读取这些变量）
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change_me_neo4j_password

# ============================================================================
# 对象存储配置 - 阿里云 OSS
# ============================================================================

OSS_ACCESS_KEY_ID=your_oss_access_key_id
OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret
OSS_REGION=oss-cn-shanghai
OSS_ENDPOINT=https://oss-cn-shanghai.aliyuncs.com
OSS_BUCKET_NAME=your-bucket-name

# ============================================================================
# JWT 认证配置
# ============================================================================

# JWT 密钥（必需 - 生产环境务必使用强随机字符串）
JWT_SECRET_KEY=change_me_jwt_secret_key

# JWT 算法
JWT_ALGORITHM=HS256

# Access Token 过期时间（秒）- 默认 24 小时
JWT_ACCESS_TOKEN_EXPIRES=86400

# Refresh Token 过期时间（秒）- 默认 7 天
JWT_REFRESH_TOKEN_EXPIRES=604800

# ============================================================================
# Redis 配置
# ============================================================================

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD 见上方 Docker 基础设施配置

# ============================================================================
# 应用配置
# ============================================================================

# 应用运行模式（development / production）
APP_ENV=production

# 日志级别（DEBUG / INFO / WARNING / ERROR）
LOG_LEVEL=INFO

# 日志目录（Docker 中默认输出 stdout，此路径仅用于文件日志兜底）
LOG_DIR=logs

# FastAPI 服务配置
API_HOST=0.0.0.0
API_PORT=8000

# ============================================================================
# LangGraph 配置
# ============================================================================

# 是否启用 PostgreSQL Checkpoint 持久化（生产环境建议 true）
LANGGRAPH_ENABLE_CHECKPOINT=true

# LangGraph Studio 调试模式（仅开发环境使用）
LANGGRAPH_STUDIO_MODE=false

# ============================================================================
# 文档处理配置
# ============================================================================

# 文档切块大小
CHUNK_SIZE=1000

# 文档切块重叠大小
CHUNK_OVERLAP=200

# 最大文档大小（MB）
MAX_DOCUMENT_SIZE=50

# ============================================================================
# 检索配置
# ============================================================================

# 默认检索模式（vector_only / graph_only / auto / no_retrieval）
DEFAULT_RETRIEVAL_MODE=auto

# 向量检索 TopK 数量
VECTOR_SEARCH_TOP_K=5

# 图检索模式（local / global / hybrid）
GRAPH_SEARCH_MODE=hybrid

